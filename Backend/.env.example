# Application
APP_PORT=8080
CORS_ALLOWED_ORIGINS=https://yourvotingsite.com

# MariaDB
DB_DSN=voting_user:voting_pass@tcp(mariadb:3306)/voting_db?parseTime=true&charset=utf8mb4

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change_me_to_a_long_random_string_in_production

# Default admin credentials (used only if admins table is empty)
ADMIN_DEFAULT_EMAIL=admin@vote.com
ADMIN_DEFAULT_PASSWORD=Admin@1234

# SMTP settings (Gmail example — use an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your@gmail.com

# Cloudflare Turnstile
TURNSTILE_SECRET=your_cloudflare_turnstile_secret_key

# Rate limiting: max OTP requests per IP per hour
RATE_LIMIT_MAX=5
