# Base URL of the Go backend (no trailing slash)
VITE_API_URL=http://localhost:8071

# Cloudflare Turnstile public site key
# Get yours at: https://dash.cloudflare.com/?to=/:account/turnstile
# Use 1x00000000000000000000AA for local testing (always passes)
VITE_CF_TURNSTILE_SITE_KEY=1x00000000000000000000AA
